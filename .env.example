# === Dashboard ===
DASHBOARD_PORT=3000

# WAJIB: Ganti dengan string acak panjang (min 32 karakter). Jangan pernah pakai nilai default ini!
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=ganti-dengan-string-acak-minimal-32-karakter-WAJIB-GANTI

# Opsional: batasi CORS hanya ke domain tertentu (pisah koma jika lebih dari satu)
# Kosongkan = semua origin diterima (hanya untuk development lokal)
# ALLOWED_ORIGINS=https://dashboard.bisnisku.com,https://www.bisnisku.com

# === AI Provider (opsional) ===
# Pilih salah satu: free / gemini / openai
AI_PROVIDER=free
# Isi API key jika menggunakan gemini atau openai
AI_API_KEY=
